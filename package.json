    "@pinia/nuxt": "^0.11.3",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.5",
    "nuxt-time": "^1.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.16.0",
    "@iconify-json/lineicons": "^1.2.6",
    "@iconify-json/mynaui": "^1.2.17",
    "@iconify-json/logos": "^1.2.4",
